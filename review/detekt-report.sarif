            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/naming#variablenaming",
              "id": "detekt.naming.VariableNaming",
              "name": "VariableNaming",
              "shortDescription": {
                "text": "Variable names should follow the naming convention set in detekt's configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/performance#arrayprimitive",
              "id": "detekt.performance.ArrayPrimitive",
              "name": "ArrayPrimitive",
              "shortDescription": {
                "text": "Using `Array<Primitive>` leads to implicit boxing and a performance hit."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/performance#couldbesequence",
              "id": "detekt.performance.CouldBeSequence",
              "name": "CouldBeSequence",
              "shortDescription": {
                "text": "Several chained collection operations that should be a sequence."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/performance#foreachonrange",
              "id": "detekt.performance.ForEachOnRange",
              "name": "ForEachOnRange",
              "shortDescription": {
                "text": "Using the forEach method on ranges has a heavy performance cost. Prefer using simple for loops."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/performance#spreadoperator",
              "id": "detekt.performance.SpreadOperator",
              "name": "SpreadOperator",
              "shortDescription": {
                "text": "In most cases using a spread operator causes a full copy of the array to be created before calling a method. This may result in a performance penalty."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/performance#unnecessaryinitonarray",
              "id": "detekt.performance.UnnecessaryInitOnArray",
              "name": "UnnecessaryInitOnArray",
              "shortDescription": {
                "text": "Flags array constructors that use lambda builders returning the same default value when the default initialization would produce the same result."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/performance#unnecessarypartofbinaryexpression",
              "id": "detekt.performance.UnnecessaryPartOfBinaryExpression",
              "name": "UnnecessaryPartOfBinaryExpression",
              "shortDescription": {
                "text": "Detects unnecessary checks in binary expressions."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/performance#unnecessarytemporaryinstantiation",
              "id": "detekt.performance.UnnecessaryTemporaryInstantiation",
              "name": "UnnecessaryTemporaryInstantiation",
              "shortDescription": {
                "text": "Avoid temporary objects when converting primitive types to `String`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/performance#unnecessarytypecasting",
              "id": "detekt.performance.UnnecessaryTypeCasting",
              "name": "UnnecessaryTypeCasting",
              "shortDescription": {
                "text": "Unnecessary type casting is found. Consider using type checking."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#magicnumber",
              "id": "detekt.style.MagicNumber",
              "name": "MagicNumber",
              "shortDescription": {
                "text": "Report magic numbers. Magic number is a numeric literal that is not defined as a constant and hence it's unclear what the purpose of this number is. It's better to declare such numbers as constants and give them a proper name. By default, -1, 0, 1, and 2 are not considered to be magic numbers."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#maxlinelength",
              "id": "detekt.style.MaxLineLength",
              "name": "MaxLineLength",
              "shortDescription": {
                "text": "Line detected, which is longer than the defined maximum line length in the code style."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unusedprivatefunction",
              "id": "detekt.style.UnusedPrivateFunction",
              "name": "UnusedPrivateFunction",
              "shortDescription": {
                "text": "Private function is unused and should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#abstractclasscanbeconcreteclass",
              "id": "detekt.style.AbstractClassCanBeConcreteClass",
              "name": "AbstractClassCanBeConcreteClass",
              "shortDescription": {
                "text": "An abstract class is unnecessary. May be refactored to a concrete class."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#abstractclasscanbeinterface",
              "id": "detekt.style.AbstractClassCanBeInterface",
              "name": "AbstractClassCanBeInterface",
              "shortDescription": {
                "text": "An abstract class is unnecessary. May be refactored to an interface."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#alsocouldbeapply",
              "id": "detekt.style.AlsoCouldBeApply",
              "name": "AlsoCouldBeApply",
              "shortDescription": {
                "text": "When an `also` block contains only `it`-started expressions, simplify it to the `apply` block."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#bracesonifstatements",
              "id": "detekt.style.BracesOnIfStatements",
              "name": "BracesOnIfStatements",
              "shortDescription": {
                "text": "Braces do not comply with the specified policy"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#bracesonwhenstatements",
              "id": "detekt.style.BracesOnWhenStatements",
              "name": "BracesOnWhenStatements",
              "shortDescription": {
                "text": "Braces do not comply with the specified policy"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#canbenonnullable",
              "id": "detekt.style.CanBeNonNullable",
              "name": "CanBeNonNullable",
              "shortDescription": {
                "text": "Variable can be changed to non-nullable, as it is never set to null."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#cascadingcallwrapping",
              "id": "detekt.style.CascadingCallWrapping",
              "name": "CascadingCallWrapping",
              "shortDescription": {
                "text": "If a chained call is wrapped to a new line, subsequent chained calls should be as well."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#classordering",
              "id": "detekt.style.ClassOrdering",
              "name": "ClassOrdering",
              "shortDescription": {
                "text": "Class contents should be in this order: Property declarations/initializer blocks; secondary constructors; method declarations then companion objects."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#collapsibleifstatements",
              "id": "detekt.style.CollapsibleIfStatements",
              "name": "CollapsibleIfStatements",
              "shortDescription": {
                "text": "Two if statements which could be collapsed were detected. These statements can be merged to improve readability."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#dataclasscontainsfunctions",
              "id": "detekt.style.DataClassContainsFunctions",
              "name": "DataClassContainsFunctions",
              "shortDescription": {
                "text": "Data classes should mainly be used to store data and should not have any extra functions (Compiler will automatically generate equals, toString and hashCode functions)."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#dataclassshouldbeimmutable",
              "id": "detekt.style.DataClassShouldBeImmutable",
              "name": "DataClassShouldBeImmutable",
              "shortDescription": {
                "text": "Data classes should mainly be immutable and should not have any side effects (To copy an object altering some of its properties use the copy function)."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#destructuringdeclarationwithtoomanyentries",
              "id": "detekt.style.DestructuringDeclarationWithTooManyEntries",
              "name": "DestructuringDeclarationWithTooManyEntries",
              "shortDescription": {
                "text": "Too many entries in a destructuring declaration make the code hard to understand."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#doublenegativeexpression",
              "id": "detekt.style.DoubleNegativeExpression",
              "name": "DoubleNegativeExpression",
              "shortDescription": {
                "text": "Expression with two or more calls of operator `not` could be simplified."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#doublenegativelambda",
              "id": "detekt.style.DoubleNegativeLambda",
              "name": "DoubleNegativeLambda",
              "shortDescription": {
                "text": "Double negative from a function name expressed in the negative (like `takeUnless`) with a lambda block that also contains negation. This is more readable when rewritten using a positive form of the function (like `takeIf`)."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#equalsnullcall",
              "id": "detekt.style.EqualsNullCall",
              "name": "EqualsNullCall",
              "shortDescription": {
                "text": "Equals() method is called with null as parameter. Consider using == to compare to null."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#equalsonsignatureline",
              "id": "detekt.style.EqualsOnSignatureLine",
              "name": "EqualsOnSignatureLine",
              "shortDescription": {
                "text": "Equals signs for expression style functions should be on the same line as the signature."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#explicitcollectionelementaccessmethod",
              "id": "detekt.style.ExplicitCollectionElementAccessMethod",
              "name": "ExplicitCollectionElementAccessMethod",
              "shortDescription": {
                "text": "Prefer usage of the indexed access operator [] for map element access or insert methods."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#explicititlambdamultipleparameters",
              "id": "detekt.style.ExplicitItLambdaMultipleParameters",
              "name": "ExplicitItLambdaMultipleParameters",
              "shortDescription": {
                "text": "Declaring lambda parameters as `it` is inappropriate."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#explicititlambdaparameter",
              "id": "detekt.style.ExplicitItLambdaParameter",
              "name": "ExplicitItLambdaParameter",
              "shortDescription": {
                "text": "Declaring lambda parameters as `it` is redundant."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#expressionbodysyntax",
              "id": "detekt.style.ExpressionBodySyntax",
              "name": "ExpressionBodySyntax",
              "shortDescription": {
                "text": "Functions with exact one statement, the return statement, can be rewritten with ExpressionBodySyntax."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#forbiddenannotation",
              "id": "detekt.style.ForbiddenAnnotation",
              "name": "ForbiddenAnnotation",
              "shortDescription": {
                "text": "Avoid using this annotation."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#forbiddencomment",
              "id": "detekt.style.ForbiddenComment",
              "name": "ForbiddenComment",
              "shortDescription": {
                "text": "Flags a forbidden comment."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#forbiddenimport",
              "id": "detekt.style.ForbiddenImport",
              "name": "ForbiddenImport",
              "shortDescription": {
                "text": "Mark forbidden imports. A forbidden import could be an import for an unstable / experimental api and hence you might want to mark it as forbidden in order to get warned about the usage."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#forbiddenmethodcall",
              "id": "detekt.style.ForbiddenMethodCall",
              "name": "ForbiddenMethodCall",
              "shortDescription": {
                "text": "Mark forbidden methods. A forbidden method could be an invocation of an unstable / experimental method and hence you might want to mark it as forbidden in order to get warned about the usage."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#forbiddennamedparam",
              "id": "detekt.style.ForbiddenNamedParam",
              "name": "ForbiddenNamedParam",
              "shortDescription": {
                "text": "Mark the methods/constructors where using named param is forbidden."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#forbiddenoptin",
              "id": "detekt.style.ForbiddenOptIn",
              "name": "ForbiddenOptIn",
              "shortDescription": {
                "text": "Using this opt-in is forbidden."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#forbiddensuppress",
              "id": "detekt.style.ForbiddenSuppress",
              "name": "ForbiddenSuppress",
              "shortDescription": {
                "text": "Suppressing a rule which is forbidden in current configuration."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#forbiddenvoid",
              "id": "detekt.style.ForbiddenVoid",
              "name": "ForbiddenVoid",
              "shortDescription": {
                "text": "`Unit` should be used instead of `Void`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#functiononlyreturningconstant",
              "id": "detekt.style.FunctionOnlyReturningConstant",
              "name": "FunctionOnlyReturningConstant",
              "shortDescription": {
                "text": "A function that only returns a constant is misleading. Consider declaring a constant instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#loopwithtoomanyjumpstatements",
              "id": "detekt.style.LoopWithTooManyJumpStatements",
              "name": "LoopWithTooManyJumpStatements",
              "shortDescription": {
                "text": "The loop contains more than one break or continue statement. The code should be refactored to increase readability."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#mandatorybracesloops",
              "id": "detekt.style.MandatoryBracesLoops",
              "name": "MandatoryBracesLoops",
              "shortDescription": {
                "text": "A multi-line loop was found that does not have braces. These should be added to improve readability."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#maxchainedcallsonsameline",
              "id": "detekt.style.MaxChainedCallsOnSameLine",
              "name": "MaxChainedCallsOnSameLine",
              "shortDescription": {
                "text": "Chained calls beyond the maximum should be wrapped to a new line."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#maybeconstant",
              "id": "detekt.style.MayBeConstant",
              "name": "MayBeConstant",
              "shortDescription": {
                "text": "Usage of `vals` that can be `const val` detected."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#modifierorder",
              "id": "detekt.style.ModifierOrder",
              "name": "ModifierOrder",
              "shortDescription": {
                "text": "Modifiers are not in the correct order. Consider to reorder these modifiers."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#multilinelambdaitparameter",
              "id": "detekt.style.MultilineLambdaItParameter",
              "name": "MultilineLambdaItParameter",
              "shortDescription": {
                "text": "Multiline lambdas should not use `it` as a parameter name."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#multilinerawstringindentation",
              "id": "detekt.style.MultilineRawStringIndentation",
              "name": "MultilineRawStringIndentation",
              "shortDescription": {
                "text": "The indentation of the raw String should be consistent"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#nestedclassesvisibility",
              "id": "detekt.style.NestedClassesVisibility",
              "name": "NestedClassesVisibility",
              "shortDescription": {
                "text": "The explicit public modifier still results in an internal nested class."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#newlineatendoffile",
              "id": "detekt.style.NewLineAtEndOfFile",
              "name": "NewLineAtEndOfFile",
              "shortDescription": {
                "text": "Checks whether files end with a line separator."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#notabs",
              "id": "detekt.style.NoTabs",
              "name": "NoTabs",
              "shortDescription": {
                "text": "Checks if tabs are used in Kotlin files."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#nullablebooleancheck",
              "id": "detekt.style.NullableBooleanCheck",
              "name": "NullableBooleanCheck",
              "shortDescription": {
                "text": "Nullable boolean check should use `==` rather than `?:`"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#objectliteraltolambda",
              "id": "detekt.style.ObjectLiteralToLambda",
              "name": "ObjectLiteralToLambda",
              "shortDescription": {
                "text": "Report object literals that can be changed to lambdas."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#optionalabstractkeyword",
              "id": "detekt.style.OptionalAbstractKeyword",
              "name": "OptionalAbstractKeyword",
              "shortDescription": {
                "text": "Unnecessary abstract modifier in interface detected. This abstract modifier is unnecessary and thus can be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#optionalunit",
              "id": "detekt.style.OptionalUnit",
              "name": "OptionalUnit",
              "shortDescription": {
                "text": "Return type of `Unit` is unnecessary and can be safely removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#protectedmemberinfinalclass",
              "id": "detekt.style.ProtectedMemberInFinalClass",
              "name": "ProtectedMemberInFinalClass",
              "shortDescription": {
                "text": "Member with protected visibility in final class is private. Consider using private or internal as modifier."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#rangeuntilinsteadofrangeto",
              "id": "detekt.style.RangeUntilInsteadOfRangeTo",
              "name": "RangeUntilInsteadOfRangeTo",
              "shortDescription": {
                "text": "A `..` call can be replaced with `..<`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#redundantconstructorkeyword",
              "id": "detekt.style.RedundantConstructorKeyword",
              "name": "RedundantConstructorKeyword",
              "shortDescription": {
                "text": "Redundant `constructor` modifier can be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#redundantexplicittype",
              "id": "detekt.style.RedundantExplicitType",
              "name": "RedundantExplicitType",
              "shortDescription": {
                "text": "Type does not need to be stated explicitly and can be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#redundanthigherordermapusage",
              "id": "detekt.style.RedundantHigherOrderMapUsage",
              "name": "RedundantHigherOrderMapUsage",
              "shortDescription": {
                "text": "Checks for redundant 'map' calls, which can be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#redundantvisibilitymodifier",
              "id": "detekt.style.RedundantVisibilityModifier",
              "name": "RedundantVisibilityModifier",
              "shortDescription": {
                "text": "Redundant visibility modifiers detected, which can be safely removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#returncount",
              "id": "detekt.style.ReturnCount",
              "name": "ReturnCount",
              "shortDescription": {
                "text": "Restrict the number of return statements in methods."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#safecast",
              "id": "detekt.style.SafeCast",
              "name": "SafeCast",
              "shortDescription": {
                "text": "Prefer to use a safe cast instead of if-else-null."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#serialversionuidinserializableclass",
              "id": "detekt.style.SerialVersionUIDInSerializableClass",
              "name": "SerialVersionUIDInSerializableClass",
              "shortDescription": {
                "text": "A class which implements the Serializable interface does not define a correct serialVersionUID field. The serialVersionUID field should be a private constant long value inside a companion object."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#spacingafterpackagedeclaration",
              "id": "detekt.style.SpacingAfterPackageDeclaration",
              "name": "SpacingAfterPackageDeclaration",
              "shortDescription": {
                "text": "Violation of the package declaration style detected."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#stringshouldberawstring",
              "id": "detekt.style.StringShouldBeRawString",
              "name": "StringShouldBeRawString",
              "shortDescription": {
                "text": "The string can be converted to raw string."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#throwscount",
              "id": "detekt.style.ThrowsCount",
              "name": "ThrowsCount",
              "shortDescription": {
                "text": "Restrict the number of throw statements in methods."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#trailingwhitespace",
              "id": "detekt.style.TrailingWhitespace",
              "name": "TrailingWhitespace",
              "shortDescription": {
                "text": "Whitespaces at the end of a line are unnecessary and can be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#trimmultilinerawstring",
              "id": "detekt.style.TrimMultilineRawString",
              "name": "TrimMultilineRawString",
              "shortDescription": {
                "text": "Multiline raw strings should be followed by `trimMargin()` or `trimIndent()`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#underscoresinnumericliterals",
              "id": "detekt.style.UnderscoresInNumericLiterals",
              "name": "UnderscoresInNumericLiterals",
              "shortDescription": {
                "text": "Report missing or invalid underscores in base 10 numbers. Numeric literals should be underscore separated to increase readability."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessaryany",
              "id": "detekt.style.UnnecessaryAny",
              "name": "UnnecessaryAny",
              "shortDescription": {
                "text": "The `any {  }` usage is unnecessary."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessaryapply",
              "id": "detekt.style.UnnecessaryApply",
              "name": "UnnecessaryApply",
              "shortDescription": {
                "text": "The `apply` usage is unnecessary and can be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessarybackticks",
              "id": "detekt.style.UnnecessaryBackticks",
              "name": "UnnecessaryBackticks",
              "shortDescription": {
                "text": "Backticks are unnecessary."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessarybracesaroundtrailinglambda",
              "id": "detekt.style.UnnecessaryBracesAroundTrailingLambda",
              "name": "UnnecessaryBracesAroundTrailingLambda",
              "shortDescription": {
                "text": "Braces around trailing lambda is unnecessary."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessaryfilter",
              "id": "detekt.style.UnnecessaryFilter",
              "name": "UnnecessaryFilter",
              "shortDescription": {
                "text": "`filter()` with other collection operations may be simplified."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessaryfullyqualifiedname",
              "id": "detekt.style.UnnecessaryFullyQualifiedName",
              "name": "UnnecessaryFullyQualifiedName",
              "shortDescription": {
                "text": "Unnecessary fully qualified names make code harder to read. Use imports instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessaryinheritance",
              "id": "detekt.style.UnnecessaryInheritance",
              "name": "UnnecessaryInheritance",
              "shortDescription": {
                "text": "The extended super type is unnecessary."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessaryinnerclass",
              "id": "detekt.style.UnnecessaryInnerClass",
              "name": "UnnecessaryInnerClass",
              "shortDescription": {
                "text": "The 'inner' qualifier is unnecessary."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessarylet",
              "id": "detekt.style.UnnecessaryLet",
              "name": "UnnecessaryLet",
              "shortDescription": {
                "text": "The `let` usage is unnecessary."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessaryparentheses",
              "id": "detekt.style.UnnecessaryParentheses",
              "name": "UnnecessaryParentheses",
              "shortDescription": {
                "text": "Unnecessary parentheses don't add any value to the code and should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unnecessaryreversed",
              "id": "detekt.style.UnnecessaryReversed",
              "name": "UnnecessaryReversed",
              "shortDescription": {
                "text": "Use single sort operation instead of sorting followed by a reverse operation or vise-versa, eg. use `.sortedByDescending { .. }` instead of `.sortedBy { }.asReversed()`"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unusedimport",
              "id": "detekt.style.UnusedImport",
              "name": "UnusedImport",
              "shortDescription": {
                "text": "Unused Imports are dead code and should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unusedparameter",
              "id": "detekt.style.UnusedParameter",
              "name": "UnusedParameter",
              "shortDescription": {
                "text": "Function parameter is unused and should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unusedprivateclass",
              "id": "detekt.style.UnusedPrivateClass",
              "name": "UnusedPrivateClass",
              "shortDescription": {
                "text": "Private class is unused and should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unusedprivateproperty",
              "id": "detekt.style.UnusedPrivateProperty",
              "name": "UnusedPrivateProperty",
              "shortDescription": {
                "text": "Property is unused and should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#unusedvariable",
              "id": "detekt.style.UnusedVariable",
              "name": "UnusedVariable",
              "shortDescription": {
                "text": "Variable is unused and should be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#useanyornoneinsteadoffind",
              "id": "detekt.style.UseAnyOrNoneInsteadOfFind",
              "name": "UseAnyOrNoneInsteadOfFind",
              "shortDescription": {
                "text": "Use `any` or `none` instead of `find` and `null` checks."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#usearrayliteralsinannotations",
              "id": "detekt.style.UseArrayLiteralsInAnnotations",
              "name": "UseArrayLiteralsInAnnotations",
              "shortDescription": {
                "text": "Array literals [...] should be preferred as they are more readable than `arrayOf(...)` expressions."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#usechecknotnull",
              "id": "detekt.style.UseCheckNotNull",
              "name": "UseCheckNotNull",
              "shortDescription": {
                "text": "Use checkNotNull() instead of check() for checking not-null."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#usecheckorerror",
              "id": "detekt.style.UseCheckOrError",
              "name": "UseCheckOrError",
              "shortDescription": {
                "text": "Use check() or error() instead of throwing an IllegalStateException."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#usedataclass",
              "id": "detekt.style.UseDataClass",
              "name": "UseDataClass",
              "shortDescription": {
                "text": "Classes that do nothing but hold data should be replaced with a data class."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#useemptycounterpart",
              "id": "detekt.style.UseEmptyCounterpart",
              "name": "UseEmptyCounterpart",
              "shortDescription": {
                "text": "Instantiation of an object's \"empty\" state should use the object's \"empty\" initializer."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#useifemptyorifblank",
              "id": "detekt.style.UseIfEmptyOrIfBlank",
              "name": "UseIfEmptyOrIfBlank",
              "shortDescription": {
                "text": "Use `ifEmpty` or `ifBlank` instead of `isEmpty` or `isBlank` to assign a default value."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#useifinsteadofwhen",
              "id": "detekt.style.UseIfInsteadOfWhen",
              "name": "UseIfInsteadOfWhen",
              "shortDescription": {
                "text": "Binary expressions are better expressed using an `if` expression than a `when` expression."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#useisnullorempty",
              "id": "detekt.style.UseIsNullOrEmpty",
              "name": "UseIsNullOrEmpty",
              "shortDescription": {
                "text": "Use `isNullOrEmpty()` call instead of `x == null || x.isEmpty()`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#uselet",
              "id": "detekt.style.UseLet",
              "name": "UseLet",
              "shortDescription": {
                "text": "Use `?.let {}` instead of if/else with a null block when checking for nullable values"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#useorempty",
              "id": "detekt.style.UseOrEmpty",
              "name": "UseOrEmpty",
              "shortDescription": {
                "text": "Use `orEmpty()` call instead of `?:` with empty collection factory methods"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#userequire",
              "id": "detekt.style.UseRequire",
              "name": "UseRequire",
              "shortDescription": {
                "text": "Use require() instead of throwing an IllegalArgumentException."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#userequirenotnull",
              "id": "detekt.style.UseRequireNotNull",
              "name": "UseRequireNotNull",
              "shortDescription": {
                "text": "Use requireNotNull() instead of require() for checking not-null."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#usesumofinsteadofflatmapsize",
              "id": "detekt.style.UseSumOfInsteadOfFlatMapSize",
              "name": "UseSumOfInsteadOfFlatMapSize",
              "shortDescription": {
                "text": "Use `sumOf` instead of `flatMap` and `size/count` calls"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#uselesscallonnotnull",
              "id": "detekt.style.UselessCallOnNotNull",
              "name": "UselessCallOnNotNull",
              "shortDescription": {
                "text": "This call on a non-null reference may be reduced or removed. Some calls are intended to be called on nullable collection or text types (e.g. `String?`).When this call is used on a reference to a non-null type (e.g. `String`) it is redundant and will have no effect, so it can be removed."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#utilityclasswithpublicconstructor",
              "id": "detekt.style.UtilityClassWithPublicConstructor",
              "name": "UtilityClassWithPublicConstructor",
              "shortDescription": {
                "text": "The class declaration is unnecessary because it only contains utility functions. An object declaration should be used instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#varcouldbeval",
              "id": "detekt.style.VarCouldBeVal",
              "name": "VarCouldBeVal",
              "shortDescription": {
                "text": "Var declaration could be val."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/style#wildcardimport",
              "id": "detekt.style.WildcardImport",
              "name": "WildcardImport",
              "shortDescription": {
                "text": "Wildcard imports should be replaced with imports using fully qualified class names. Wildcard imports can lead to naming conflicts. A library update can introduce naming clashes with your classes which results in compilation errors."
              }
            }
          ]
        }
      }
    }
  ]
}
