            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/exceptions#errorusagewiththrowable",
              "id": "detekt.exceptions.ErrorUsageWithThrowable",
              "name": "ErrorUsageWithThrowable",
              "shortDescription": {
                "text": "Passing `Throwable` in `error` method is ambiguous. Use `error(throwable.message ?: \"No error message provided\")` instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/exceptions#exceptionraisedinunexpectedlocation",
              "id": "detekt.exceptions.ExceptionRaisedInUnexpectedLocation",
