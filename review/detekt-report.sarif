              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/potential-bugs#uselesspostfixexpression",
              "id": "detekt.potential-bugs.UselessPostfixExpression",
              "name": "UselessPostfixExpression",
              "shortDescription": {
                "text": "The incremented or decremented value is unused. This value is replaced with the original value."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/potential-bugs#wrongequalstypeparameter",
