            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/potential-bugs#missingusecall",
              "id": "detekt.potential-bugs.MissingUseCall",
              "name": "MissingUseCall",
              "shortDescription": {
                "text": "Usage of `Closeable` detected without `use` call. Using `Closeable` without `use` can be problematic as closing `Closeable` may throw exception."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
