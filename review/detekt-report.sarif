              "id": "detekt.potential-bugs.LateinitUsage",
              "name": "LateinitUsage",
              "shortDescription": {
                "text": "Usage of `lateinit` detected. Using `lateinit` for property initialization is error prone, try using constructor injection or delegation."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
