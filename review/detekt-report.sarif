              "id": "detekt.potential-bugs.NullCheckOnMutableProperty",
              "name": "NullCheckOnMutableProperty",
              "shortDescription": {
                "text": "Checking nullability on a mutable property is not useful because the property may be set to null afterwards."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
