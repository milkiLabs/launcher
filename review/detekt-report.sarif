                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/potential-bugs#missingsupercall",
              "id": "detekt.potential-bugs.MissingSuperCall",
              "name": "MissingSuperCall",
              "shortDescription": {
                "text": "Overriding method is missing a call to overridden super method."
