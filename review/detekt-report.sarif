      "tool": {
        "driver": {
          "guid": "022ca8c2-f6a2-4c95-b107-bb72c43263f3",
          "informationUri": "https://detekt.dev",
          "language": "en",
          "name": "detekt",
          "organization": "detekt",
          "rules": [
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#longparameterlist",
              "id": "detekt.complexity.LongParameterList",
              "name": "LongParameterList",
              "shortDescription": {
                "text": "The more parameters a function has the more complex it is. Long parameter lists are often used to control complex algorithms and violate the Single Responsibility Principle. Prefer functions with short parameter lists."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#toomanyfunctions",
              "id": "detekt.complexity.TooManyFunctions",
              "name": "TooManyFunctions",
              "shortDescription": {
                "text": "Too many functions inside a/an file/class/object/interface always indicate a violation of the single responsibility principle. Maybe the file/class/object/interface wants to manage too many things at once. Extract functionality which clearly belongs together."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#cognitivecomplexmethod",
              "id": "detekt.complexity.CognitiveComplexMethod",
              "name": "CognitiveComplexMethod",
              "shortDescription": {
                "text": "Prefer splitting up complex methods into smaller, easier to understand methods."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#complexcondition",
              "id": "detekt.complexity.ComplexCondition",
              "name": "ComplexCondition",
              "shortDescription": {
                "text": "Complex conditions should be simplified and extracted into well-named methods if necessary."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#complexinterface",
              "id": "detekt.complexity.ComplexInterface",
              "name": "ComplexInterface",
              "shortDescription": {
                "text": "An interface contains too many functions and properties. Large classes tend to handle many things at once. An interface should have one responsibility. Split up large interfaces into smaller ones that are easier to understand."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#cyclomaticcomplexmethod",
              "id": "detekt.complexity.CyclomaticComplexMethod",
              "name": "CyclomaticComplexMethod",
              "shortDescription": {
                "text": "Prefer splitting up complex methods into smaller, easier to test methods."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#labeledexpression",
              "id": "detekt.complexity.LabeledExpression",
              "name": "LabeledExpression",
              "shortDescription": {
                "text": "Expression with labels increase complexity and affect maintainability."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#largeclass",
              "id": "detekt.complexity.LargeClass",
              "name": "LargeClass",
              "shortDescription": {
                "text": "One class should have one responsibility. Large classes tend to handle many things at once. Split up large classes into smaller classes that are easier to understand."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#longmethod",
              "id": "detekt.complexity.LongMethod",
              "name": "LongMethod",
              "shortDescription": {
                "text": "One method should have one responsibility. Long methods tend to handle many things at once. Prefer smaller methods to make them easier to understand."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#methodoverloading",
              "id": "detekt.complexity.MethodOverloading",
              "name": "MethodOverloading",
              "shortDescription": {
                "text": "Methods which are overloaded often might be harder to maintain. Furthermore, these methods are tightly coupled. Refactor these methods and try to use optional parameters."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#namedarguments",
              "id": "detekt.complexity.NamedArguments",
              "name": "NamedArguments",
              "shortDescription": {
                "text": "Named arguments are required for function calls with many arguments."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#nestedblockdepth",
              "id": "detekt.complexity.NestedBlockDepth",
              "name": "NestedBlockDepth",
              "shortDescription": {
                "text": "Excessive nesting leads to hidden complexity. Prefer extracting code to make it easier to understand."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#nestedscopefunctions",
              "id": "detekt.complexity.NestedScopeFunctions",
              "name": "NestedScopeFunctions",
              "shortDescription": {
                "text": "Over-using scope functions makes code confusing, hard to read and bug prone."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#replacesafecallchainwithrun",
              "id": "detekt.complexity.ReplaceSafeCallChainWithRun",
              "name": "ReplaceSafeCallChainWithRun",
              "shortDescription": {
                "text": "Chains of safe calls on non-nullable types can be surrounded with `run {}`."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/complexity#stringliteralduplication",
              "id": "detekt.complexity.StringLiteralDuplication",
              "name": "StringLiteralDuplication",
              "shortDescription": {
                "text": "Multiple occurrences of the same string literal within a single file detected. Prefer extracting the string literal into a property or constant."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#coroutinelaunchedintestwithoutruntest",
              "id": "detekt.coroutines.CoroutineLaunchedInTestWithoutRunTest",
              "name": "CoroutineLaunchedInTestWithoutRunTest",
              "shortDescription": {
                "text": "Launching coroutines in tests without a `runTest` block could swallow exceptions. You should use `runTest` to avoid altering test results."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#globalcoroutineusage",
              "id": "detekt.coroutines.GlobalCoroutineUsage",
              "name": "GlobalCoroutineUsage",
              "shortDescription": {
                "text": "The usage of the `GlobalScope` instance is highly discouraged."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#injectdispatcher",
              "id": "detekt.coroutines.InjectDispatcher",
              "name": "InjectDispatcher",
              "shortDescription": {
                "text": "Don't hardcode dispatchers when creating new coroutines or calling `withContext`. Use dependency injection for dispatchers to make testing easier."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#redundantsuspendmodifier",
              "id": "detekt.coroutines.RedundantSuspendModifier",
              "name": "RedundantSuspendModifier",
              "shortDescription": {
                "text": "The `suspend` modifier is only needed for functions that contain suspending calls."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#sleepinsteadofdelay",
              "id": "detekt.coroutines.SleepInsteadOfDelay",
              "name": "SleepInsteadOfDelay",
              "shortDescription": {
                "text": "Usage of `Thread.sleep()` in coroutines can potentially halt multiple coroutines at once."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#suspendfuninfinallysection",
              "id": "detekt.coroutines.SuspendFunInFinallySection",
              "name": "SuspendFunInFinallySection",
              "shortDescription": {
                "text": "Suspend functions should not be called from a 'finally' section without using 'NonCancellable' context as they won't execute if parent coroutine scope is cancelled."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#suspendfunswallowedcancellation",
              "id": "detekt.coroutines.SuspendFunSwallowedCancellation",
              "name": "SuspendFunSwallowedCancellation",
              "shortDescription": {
                "text": "`CancellationException` must be specially handled and re-thrown when working with exceptions in a suspending context. This includes `runCatching` as well as regular try-catch blocks."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#suspendfunwithcoroutinescopereceiver",
              "id": "detekt.coroutines.SuspendFunWithCoroutineScopeReceiver",
              "name": "SuspendFunWithCoroutineScopeReceiver",
              "shortDescription": {
                "text": "The `suspend` modifier should not be used for functions that use a CoroutinesScope as receiver. You should use suspend functions without the receiver or use plain functions and use coroutineScope { } instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/coroutines#suspendfunwithflowreturntype",
              "id": "detekt.coroutines.SuspendFunWithFlowReturnType",
              "name": "SuspendFunWithFlowReturnType",
              "shortDescription": {
                "text": "The `suspend` modifier should not be used for functions that return a Coroutines Flow type. Flows are cold streams and invoking a function that returns one should not produce any side effects."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#absentorwrongfilelicense",
              "id": "detekt.comments.AbsentOrWrongFileLicense",
              "name": "AbsentOrWrongFileLicense",
              "shortDescription": {
                "text": "License text is absent or incorrect."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#deprecatedblocktag",
              "id": "detekt.comments.DeprecatedBlockTag",
              "name": "DeprecatedBlockTag",
              "shortDescription": {
                "text": "Do not use the `@deprecated` block tag, which is not supported by KDoc. Use the `@Deprecated` annotation instead."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#documentationoverprivatefunction",
              "id": "detekt.comments.DocumentationOverPrivateFunction",
              "name": "DocumentationOverPrivateFunction",
              "shortDescription": {
                "text": "Comments for private functions should be avoided. Prefer giving the function an expressive name. Split it up in smaller, self-explaining functions if necessary."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#documentationoverprivateproperty",
              "id": "detekt.comments.DocumentationOverPrivateProperty",
              "name": "DocumentationOverPrivateProperty",
              "shortDescription": {
                "text": "Private properties should be named in a self-explanatory manner without the need for a  comment."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#endofsentenceformat",
              "id": "detekt.comments.EndOfSentenceFormat",
              "name": "EndOfSentenceFormat",
              "shortDescription": {
                "text": "The first sentence in a KDoc comment should end with proper punctuation or with a correct URL."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#kdocreferencesnonpublicproperty",
              "id": "detekt.comments.KDocReferencesNonPublicProperty",
              "name": "KDocReferencesNonPublicProperty",
              "shortDescription": {
                "text": "KDoc comments should not refer to non-public properties."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#outdateddocumentation",
              "id": "detekt.comments.OutdatedDocumentation",
              "name": "OutdatedDocumentation",
              "shortDescription": {
                "text": "KDoc comments should match the actual function or class signature"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#undocumentedpublicclass",
              "id": "detekt.comments.UndocumentedPublicClass",
              "name": "UndocumentedPublicClass",
              "shortDescription": {
                "text": "Public classes, interfaces and objects require documentation."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#undocumentedpublicfunction",
              "id": "detekt.comments.UndocumentedPublicFunction",
              "name": "UndocumentedPublicFunction",
              "shortDescription": {
                "text": "Public functions require documentation."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": false,
                "level": "error"
              },
              "helpUri": "https://detekt.dev/docs/2.0.0-alpha.2/rules/comments#undocumentedpublicproperty",
              "id": "detekt.comments.UndocumentedPublicProperty",
              "name": "UndocumentedPublicProperty",
              "shortDescription": {
                "text": "Public properties require documentation."
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
